{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "."  // Cambia de "./src" a "."
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}